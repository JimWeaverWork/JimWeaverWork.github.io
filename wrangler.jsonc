{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "jimweaverwork-github-io",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    {
      "pattern": "jimweaver.com",
      "custom_domain": true
    }
  ]
}
